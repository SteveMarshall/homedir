fontName         = "SF Mono"
fontSize         = 11
include          = {*,.tm_properties,.htaccess,.htpasswd,.gitignore,.kitchen.yml,.travis.yml,.swiftlint.yml,.env,.github,.well-known,.dockerignore}
showInvisibles   = true
showWrapColumn   = true
softTabs         = true
softWrap         = false
# Use cmark-gfm for the Markdown preview so tables render (Markdown.pl can't)
TM_MARKDOWN      = "/opt/homebrew/bin/cmark-gfm -e table -e strikethrough -e autolink"
spellChecking    = true
spellingLanguage = en_GB
wrapColumn       = 72
