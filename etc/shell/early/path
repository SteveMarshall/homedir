# ~/etc/shell/rc/path
# common updates to the default path

export PATH="/Users/Steven/.local/bin:$PATH"

PATH="${HOME}/bin:${PATH}"
PATH="${PWD}/bin:${PATH}"
PATH="${PWD}:${PATH}"

function update_local_bin_path() {
  export PATH="${PATH//:$OLDPWD\/bin:/:$PWD/bin:}"
}
chpwd_functions=(${chpwd_functions[@]} "update_local_bin_path")
